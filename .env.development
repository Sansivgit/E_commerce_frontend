# Leave VITE_API_URL unset for local dev so the app calls same-origin `/api/*`.
# Vite proxies `/api` to Express at http://127.0.0.1:5000 (see vite.config.ts) — avoids CORS when the UI runs on any port (8080, 5173, …).
#
# If you set VITE_API_URL=http://localhost:5000 instead, add your storefront origin to the backend `CLIENT_URL` (e.g. http://localhost:8080) or the browser will block with CORS.

# Razorpay public key (Checkout). Must match the key id in the backend.
VITE_RAZORPAY_KEY_ID=rzp_test_Snh6GjGsBzuwL6

