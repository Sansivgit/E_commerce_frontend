# Frontend (Vite) — public env only `VITE_*` is exposed to the browser.

# Customer app URL (absolute links, “View store”, etc.). Must match how you open the storefront.
VITE_STORE_URL=http://localhost:8080

# Express API base (no trailing slash). In dev the app calls this host directly for `/api/*`
# so the TanStack dev server does not return HTML for API routes. Must match your running backend.
VITE_BACKEND_ORIGIN=http://localhost:5000

# Optional: call the API directly (skips proxy). Leave unset for normal local dev.
# VITE_API_URL=http://localhost:5000

VITE_RAZORPAY_KEY_ID=rzp_test_Snh6GjGsBzuwL6
