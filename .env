# Public env for Vite — single file for this app.
# Only `VITE_*` variables are exposed to client code.
#
# Backend API (Render). No trailing slash. Must be listed in backend `CLIENT_URL` for CORS.
VITE_API_URL=https://e-commerce-backend-ajck.onrender.com

# Razorpay Checkout public key — must match the key id configured in the backend
VITE_RAZORPAY_KEY_ID=rzp_test_Snh6GjGsBzuwL6
