# Public env for Vite (optional).
#
# Local dev: omit `VITE_API_URL` so auth calls use `/api` on the same origin; Vite dev server proxies to Express (see `vite.config.ts`).
#
# Direct cross-origin API (or production): set the full backend URL (no trailing slash).
# VITE_API_URL=https://api.example.com
#
# Razorpay (public key id for Checkout; use your test or live id).
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
